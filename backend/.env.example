# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gomopood
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=gomopood@gmail.com
SMTP_FROM_NAME=GOMOPOOD

# Payment Gateway - Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Mobile Money API - MTN
MTN_API_KEY=your_mtn_api_key
MTN_API_URL=https://api.mtn.co.ug
MTN_MERCHANT_ID=your_mtn_merchant_id

# Mobile Money API - Airtel
AIRTEL_API_KEY=your_airtel_api_key
AIRTEL_API_URL=https://api.airtel.co.ug
AIRTEL_MERCHANT_ID=your_airtel_merchant_id

# Admin Credentials (for initial setup)
ADMIN_EMAIL=admin@gomopood.com
ADMIN_PASSWORD=Change_Me_In_Production_123!

# Features
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_PAYMENT_LOGGING=true

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# Session
SESSION_SECRET=your_session_secret_key_here
SESSION_TIMEOUT=3600000
